# Discord Webhook URL for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Discord サーバー招待リンク（X投稿に添付）
DISCORD_INVITE_URL=https://discord.gg/xxxxxxx

# Amazon Affiliate tag (Amazonアソシエイト、直接タグ付きリンクを生成)
AMAZON_AFFILIATE_TAG=yourtag-22

# 楽天ウェブサービス (楽天市場商品検索APIで直接アフィリエイトURLを取得。gacha-calendar-20p.pages.dev用に
# https://webservice.rakuten.co.jp/ で新規Webアプリケーションを登録して取得する)
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=

# Database path (default: ./data/gacha.db)
# DB_PATH=./data/gacha.db
