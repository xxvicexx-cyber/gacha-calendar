---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="お気に入り | ガチャガチャ発売カレンダー"
  description="フォローしたメーカー・シリーズの新作ガチャガチャをまとめてチェック。"
>
  <h2 style="font-size: 1.3rem; margin-bottom: 1rem;">★ お気に入り</h2>
  <p style="color: #666; font-size: 0.9rem; margin-bottom: 1.5rem;">
    商品カードの「☆ フォロー」ボタンで、気になるメーカー・シリーズを登録できます(このブラウザにのみ保存されます)。
  </p>

  <div id="favorites-empty" style="display: none; background: white; border-radius: 8px; padding: 2rem; text-align: center; color: #888;">
    <p>まだフォロー中のメーカー・シリーズがありません。</p>
    <p style="margin-top: 0.5rem;"><a href="/" style="color: #e74c3c;">トップページ</a>から気になるメーカーをフォローしてみましょう。</p>
  </div>

  <div id="favorites-tags" style="display: none; margin-bottom: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem;"></div>

  <div id="favorites-loading" style="color: #888;">読み込み中...</div>
  <div id="favorites-results" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem;"></div>
</Layout>

<script>
  import { fetchAllProducts, renderCard, type Product } from '../lib/products';

  type Favorites = { makers: string[]; ips: string[] };

  function loadFavorites(): Favorites {
    try {
      const raw = localStorage.getItem('gacha_favorites');
      if (!raw) return { makers: [], ips: [] };
      const parsed = JSON.parse(raw);
      return { makers: parsed.makers ?? [], ips: parsed.ips ?? [] };
    } catch {
      return { makers: [], ips: [] };
    }
  }

  async function main() {
    const fav = loadFavorites();
    const emptyEl = document.getElementById('favorites-empty')!;
    const tagsEl = document.getElementById('favorites-tags')!;
    const loadingEl = document.getElementById('favorites-loading')!;
    const resultsEl = document.getElementById('favorites-results')!;

    if (fav.makers.length === 0 && fav.ips.length === 0) {
      emptyEl.style.display = 'block';
      loadingEl.style.display = 'none';
      return;
    }

    tagsEl.style.display = 'flex';
    tagsEl.innerHTML = [
      ...fav.makers.map((m) => `<span style="background:#fff3cd;color:#856404;padding:0.2rem 0.6rem;border-radius:12px;font-size:0.8rem;">${m}</span>`),
      ...fav.ips.map((i) => `<span style="background:#e8f4fd;color:#0969da;padding:0.2rem 0.6rem;border-radius:12px;font-size:0.8rem;">${i}</span>`),
    ].join('');

    try {
      const allProducts: Product[] = await fetchAllProducts();

      const matched = allProducts.filter(
        (p) => (p.maker && fav.makers.includes(p.maker)) || (p.ip_tag && fav.ips.includes(p.ip_tag)),
      );
      matched.sort((a, b) => (a.release_date || a.release_month || '').localeCompare(b.release_date || b.release_month || ''));

      loadingEl.style.display = 'none';
      if (matched.length === 0) {
        resultsEl.innerHTML = `<p style="color:#888;grid-column:1/-1;">フォロー中のメーカー・シリーズの新作は見つかりませんでした。</p>`;
      } else {
        resultsEl.innerHTML = matched.map(renderCard).join('');
      }
    } catch (err) {
      loadingEl.textContent = 'データの取得に失敗しました。時間をおいて再度お試しください。';
      console.error(err);
    }
  }

  main();
</script>
