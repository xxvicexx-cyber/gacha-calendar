---
interface Props {
  title: string;
  description?: string;
  image?: string;
}
const {
  title,
  description = 'ガチャガチャ・食玩の発売カレンダー速報サイト',
  image = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ガチャガチャ発売カレンダー" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="ja_JP" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <slot name="structured-data" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f5f5f5;
      color: #333;
      line-height: 1.6;
    }
    header {
      background: #e74c3c;
      color: white;
      padding: 1rem 1.5rem;
    }
    header a { color: white; text-decoration: none; }
    header h1 { font-size: 1.4rem; }
    nav { background: #c0392b; padding: 0.5rem 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap; }
    nav a { color: white; text-decoration: none; font-size: 0.9rem; opacity: 0.85; }
    nav a:hover { opacity: 1; }
    main { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }
    footer { text-align: center; padding: 2rem; font-size: 0.8rem; color: #888; margin-top: 3rem; }
    footer a { color: #888; }
  </style>
</head>
<body>
  <header>
    <a href="/"><h1>🎰 ガチャガチャ発売カレンダー</h1></a>
  </header>
  <nav>
    <a href="/">トップ</a>
    <a href="/search">🔍 検索</a>
    <a href="/favorites">★ お気に入り</a>
    <a href="/about">このサイトについて</a>
  </nav>
  <main>
    <slot />
  </main>
  <footer>
    <p>当サイトはアフィリエイト広告（Amazon・楽天）を掲載しています。発売日は変更になる場合があります。<br>
    詳しくは<a href="/about">このサイトについて</a>をご覧ください。</p>
  </footer>
  <script>
    type Favorites = { makers: string[]; ips: string[] };
    const STORAGE_KEY = 'gacha_favorites';

    function loadFavorites(): Favorites {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { makers: [], ips: [] };
        const parsed = JSON.parse(raw);
        return { makers: parsed.makers ?? [], ips: parsed.ips ?? [] };
      } catch {
        return { makers: [], ips: [] };
      }
    }

    function saveFavorites(fav: Favorites) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(fav));
    }

    function keyFor(type: string): 'makers' | 'ips' {
      return type === 'maker' ? 'makers' : 'ips';
    }

    function applyFollowButtonState() {
      const fav = loadFavorites();
      document.querySelectorAll<HTMLButtonElement>('.follow-btn').forEach((btn) => {
        const type = btn.dataset.followType ?? '';
        const value = btn.dataset.followValue ?? '';
        const active = fav[keyFor(type)].includes(value);
        btn.setAttribute('aria-pressed', String(active));
        btn.textContent = active ? '★ フォロー中' : '☆ フォロー';
        btn.style.background = active ? '#fff3cd' : 'white';
        btn.style.borderColor = active ? '#e0a800' : '#ddd';
        btn.style.color = active ? '#856404' : '#666';
      });
    }

    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.follow-btn');
      if (!btn) return;
      const type = btn.dataset.followType ?? '';
      const value = btn.dataset.followValue ?? '';
      if (!value) return;
      const fav = loadFavorites();
      const k = keyFor(type);
      const idx = fav[k].indexOf(value);
      if (idx >= 0) fav[k].splice(idx, 1);
      else fav[k].push(value);
      saveFavorites(fav);
      applyFollowButtonState();
    });

    applyFollowButtonState();
    document.addEventListener('astro:page-load', applyFollowButtonState);
  </script>
</body>
</html>
